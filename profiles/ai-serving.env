#!/bin/bash
# Profile: ai-serving
# OpenShift AI モデルサービング環境
# OpenShift AI + NVIDIA GPU + NFD

PROFILE_NAME="ai-serving"
GITOPS_ENV="ai-serving"

# --- クラスター構成 ---
CLUSTER_VIA="terraform"
TF_VAR_rosa_machine_type="m6a.2xlarge"
TF_VAR_worker_pool_replicas="2"
TF_VAR_availability_zone_count="1"

# --- GPU ノードプール ---
GPU_MACHINE_TYPE="g5.2xlarge"
GPU_REPLICAS="1"

# --- Ansible 制御 ---
RUN_ANSIBLE="true"
ANSIBLE_PLAYBOOKS="gitops,configmaps,odh_storage"

# --- ワークショップユーザー ---
TF_VAR_admin_count="1"
TF_VAR_workshop_user_count="5"
