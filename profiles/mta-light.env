#!/bin/bash
# Profile: mta-light
# MTA 最小構成（GPU なし、AI なし）
# MTA + Keycloak + CNPG + DevSpaces

export PROFILE_NAME="mta-light"
export GITOPS_ENV="mta-light"

# --- クラスター構成 ---
export CLUSTER_VIA="terraform"
export TF_VAR_rosa_machine_type="m6a.2xlarge"
export TF_VAR_worker_pool_replicas="2"
export TF_VAR_availability_zone_count="1"

# --- GPU ノードプール（なし）---
export GPU_MACHINE_TYPE=""
export GPU_REPLICAS="0"

# --- Ansible 制御 ---
export RUN_ANSIBLE="true"
export ANSIBLE_PLAYBOOKS="gitops,configmaps,tackle_secret"

# --- ワークショップユーザー ---
export TF_VAR_admin_count="1"
export TF_VAR_workshop_user_count="20"
