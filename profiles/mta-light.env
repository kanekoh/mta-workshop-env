#!/bin/bash
# Profile: mta-light
# MTA 最小構成（GPU なし、AI なし）
# MTA + Keycloak + CNPG + DevSpaces

PROFILE_NAME="mta-light"
GITOPS_ENV="mta-light"

# --- クラスター構成 ---
CLUSTER_VIA="terraform"
TF_VAR_rosa_machine_type="m6a.2xlarge"
TF_VAR_worker_pool_replicas="2"
TF_VAR_availability_zone_count="1"

# --- GPU ノードプール（なし）---
GPU_MACHINE_TYPE=""
GPU_REPLICAS="0"

# --- Ansible 制御 ---
RUN_ANSIBLE="true"
ANSIBLE_PLAYBOOKS="gitops,configmaps,tackle_secret"

# --- ワークショップユーザー ---
TF_VAR_admin_count="1"
TF_VAR_workshop_user_count="20"
