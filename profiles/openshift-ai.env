#!/bin/bash
# Profile: openshift-ai
# OpenShift AI 3.x 最新版の操作確認環境
# RHOAI + NVIDIA GPU Operator + NFD

PROFILE_NAME="openshift-ai"
GITOPS_ENV="openshift-ai"

# --- クラスター構成 ---
CLUSTER_VIA="terraform"
TF_VAR_rosa_machine_type="m6a.2xlarge"
TF_VAR_worker_pool_replicas="2"
TF_VAR_availability_zone_count="1"

# --- GPU ノードプール ---
GPU_MACHINE_TYPE="g5.xlarge"
GPU_REPLICAS="1"

# --- Ansible 制御 ---
RUN_ANSIBLE="true"
ANSIBLE_PLAYBOOKS="gitops,configmaps,odh_storage"

# --- ワークショップユーザー ---
TF_VAR_admin_count="1"
TF_VAR_workshop_user_count="1"
