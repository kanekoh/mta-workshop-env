#!/bin/bash
# Profile: openshift-ai
# OpenShift AI 3.x 最新版の操作確認環境
# RHOAI + NVIDIA GPU Operator + NFD

export PROFILE_NAME="openshift-ai"
export GITOPS_ENV="openshift-ai"

# --- クラスター構成 ---
export CLUSTER_VIA="terraform"
export TF_VAR_rosa_machine_type="m6a.2xlarge"
export TF_VAR_worker_pool_replicas="2"
export TF_VAR_availability_zone_count="1"

# --- GPU ノードプール ---
export GPU_MACHINE_TYPE="g5.xlarge"
export GPU_REPLICAS="1"

# --- Ansible 制御 ---
export RUN_ANSIBLE="true"
export ANSIBLE_PLAYBOOKS="gitops,configmaps,odh_storage"

# --- ワークショップユーザー ---
export TF_VAR_admin_count="1"
export TF_VAR_workshop_user_count="1"
