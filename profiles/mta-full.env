#!/bin/bash
# Profile: mta-full
# MTA for Developer Lightspeed フルワークショップ環境
# OpenShift AI + GPU + MTA + Keycloak + DevSpaces

export PROFILE_NAME="mta-full"
export GITOPS_ENV="mta"

# --- クラスター構成 ---
export CLUSTER_VIA="terraform"
export TF_VAR_rosa_machine_type="m6a.2xlarge"
export TF_VAR_worker_pool_replicas="3"
export TF_VAR_availability_zone_count="1"

# --- GPU ノードプール ---
export GPU_MACHINE_TYPE="g5.xlarge"
export GPU_REPLICAS="1"

# --- Ansible 制御 ---
export RUN_ANSIBLE="true"
export ANSIBLE_PLAYBOOKS="gitops,configmaps,tackle_secret,odh_storage"

# --- ワークショップユーザー ---
export TF_VAR_admin_count="2"
export TF_VAR_workshop_user_count="30"
