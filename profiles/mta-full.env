#!/bin/bash
# Profile: mta-full
# MTA for Developer Lightspeed フルワークショップ環境
# OpenShift AI + GPU + MTA + Keycloak + DevSpaces

PROFILE_NAME="mta-full"
GITOPS_ENV="mta"

# --- クラスター構成 ---
CLUSTER_VIA="terraform"
TF_VAR_rosa_machine_type="m6a.2xlarge"
TF_VAR_worker_pool_replicas="3"
TF_VAR_availability_zone_count="1"

# --- GPU ノードプール ---
GPU_MACHINE_TYPE="g5.xlarge"
GPU_REPLICAS="1"

# --- Ansible 制御 ---
RUN_ANSIBLE="true"
ANSIBLE_PLAYBOOKS="gitops,configmaps,tackle_secret,odh_storage"

# --- ワークショップユーザー ---
TF_VAR_admin_count="2"
TF_VAR_workshop_user_count="30"
