#!/bin/bash
# Profile: mce-odf
# MCE (Multicluster Engine) + ODF (OpenShift Data Foundation) 環境
# ROSA マルチ AZ 上に HCP Management Cluster を構築し、ODF で分散ストレージを提供
# MCE から HyperShift で Self-Managed Hosted Cluster を作成する検証環境

export PROFILE_NAME="mce-odf"
export GITOPS_ENV="mce-odf"

# --- クラスター構成 ---
export CLUSTER_VIA="terraform"
export TF_VAR_rosa_machine_type="m6a.2xlarge"
export TF_VAR_worker_pool_replicas="0"
export TF_VAR_availability_zone_count="3"

# --- GPU ノードプール（なし）---
export GPU_MACHINE_TYPE=""
export GPU_REPLICAS="0"

# --- ODF 専用ノードプール ---
export ODF_MACHINE_TYPE="m5.4xlarge"
export ODF_REPLICAS="3"

# --- Ansible 制御 ---
export RUN_ANSIBLE="true"
export ANSIBLE_PLAYBOOKS="gitops,configmaps"

# --- ワークショップユーザー ---
export TF_VAR_admin_count="1"
export TF_VAR_workshop_user_count="1"
