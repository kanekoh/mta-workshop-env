#!/bin/bash
# Profile: observability
# Network Observability 環境
# Loki + Network Observability Operator

PROFILE_NAME="observability"
GITOPS_ENV="observ"

# --- クラスター構成 ---
CLUSTER_VIA="terraform"
TF_VAR_rosa_machine_type="m6a.xlarge"
TF_VAR_worker_pool_replicas="2"
TF_VAR_availability_zone_count="1"

# --- GPU ノードプール（なし）---
GPU_MACHINE_TYPE=""
GPU_REPLICAS="0"

# --- Ansible 制御 ---
RUN_ANSIBLE="true"
ANSIBLE_PLAYBOOKS="gitops,loki_storage"

# --- ワークショップユーザー ---
TF_VAR_admin_count="1"
TF_VAR_workshop_user_count="10"
