#!/bin/bash
# Profile: observability
# Network Observability 環境
# Loki + Network Observability Operator

export PROFILE_NAME="observability"
export GITOPS_ENV="observ"

# --- クラスター構成 ---
export CLUSTER_VIA="terraform"
export TF_VAR_rosa_machine_type="m6a.xlarge"
export TF_VAR_worker_pool_replicas="2"
export TF_VAR_availability_zone_count="1"

# --- GPU ノードプール（なし）---
export GPU_MACHINE_TYPE=""
export GPU_REPLICAS="0"

# --- Ansible 制御 ---
export RUN_ANSIBLE="true"
export ANSIBLE_PLAYBOOKS="gitops,loki_storage"

# --- ワークショップユーザー ---
export TF_VAR_admin_count="1"
export TF_VAR_workshop_user_count="10"
